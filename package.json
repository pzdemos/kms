{
  "name": "@pengzi/kms",
  "version": "1.2.0",
  "description": "High-security Key Management System for Node.js applications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "kms": "./dist/cli/kms.js",
    "kms-cli": "./dist/cli/kms.js"
  },
  "scripts": {
    "build": "tsc",
    "build:cli": "tsc cli/kms.ts --outDir dist --module commonjs --target es2020 --moduleResolution node --esModuleInterop --rootDir .",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "prepublishOnly": "npm run build && npm run build:cli"
  },
  "keywords": [
    "kms",
    "key-management",
    "security",
    "encryption",
    "vault",
    "secrets",
    "database-credentials"
  ],
  "author": "pzdemons",
  "license": "MIT",
  "dependencies": {
    "mongodb": "^6.3.0",
    "bcrypt": "^5.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/bcrypt": "^5.0.2",
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.1",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4"
  },
  "peerDependencies": {
    "mongodb": ">=6.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
